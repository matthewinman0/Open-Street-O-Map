{
  "version": 8,
  "name": "ISOM Base Style",
  "sources": {
    "osm": {
      "type": "vector",
      "tiles": [
        "https://api.maptiler.com/tiles/v3/{z}/{x}/{y}.pbf?key=SOSAfSwTZ8G9yYdNtF8Z"
      ],
      "minzoom": 0,
      "maxzoom": 14
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#ffdda3"
      }
    },
    {
      "id": "landcover-grass",
      "type": "fill",
      "source": "osm",
      "source-layer": "landcover",
      "filter": ["in", "class", "grass", "meadow"],
      "paint": {
        "fill-color": "#febe50",
        "fill-opacity": 1
      }
    },
        {
        "id": "landcover-wood",
        "type": "fill",
        "source": "osm",
        "source-layer": "landcover",
        "filter": ["in", "subclass", "forest", "wood"],
        "paint": {
            "fill-color": "#ffffff",
            "fill-opacity": 1
        }
    },
    {
      "id": "residential-areas",
      "type": "fill",
      "source": "osm",
      "source-layer": "landuse",
      "filter": ["==", "class", "residential"],
      "paint": {
        "fill-color": "#aba537",
        "fill-opacity": 1
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "osm",
      "source-layer": "water",
      "paint": {
        "fill-color": "#009ddc",
        "fill-opacity": 1
      }
    },
    {
      "id": "streams",
      "type": "line",
      "source": "osm",
      "source-layer": "waterway",
      "filter": ["in", "class", "stream", "canal", "drain"],
      "paint": {
        "line-color": "#009ddc",
        "line-opacity": 1,
        "line-width": [
              "interpolate",
              ["linear"],
              ["zoom"],
              10, 1.2,
              14, 1,
              18, 8,
              19, 30
              ]
      }
    },
    {
      "id": "walls",
      "type": "line",
      "source": "osm",
      "source-layer": "transportation",
      "filter": ["==", "class", "wall"],
      "paint": {
        "line-color": "#3a3a3a",
        "line-width": 1.2
      }
    },
    {
      "id": "fences",
      "type": "line",
      "source": "osm",
      "source-layer": "transportation",
      "filter": ["==", "class", "fence"],
      "paint": {
        "line-color": "#6b5b3e",
        "line-width": 0.8,
        "line-dasharray": [2, 2]
      }
    },
    {
        "id": "roads-motorway",
        "type": "line",
        "source": "osm",
        "source-layer": "transportation",
        "filter": ["==", "class", "motorway"],
        "paint": {
            "line-color": "#e4af7b",
            "line-width": [
              "interpolate",
              ["linear"],
              ["zoom"],
              10, 1.2,
              14, 4,
              18, 20,
              19, 30
              ]
        }
    },
    {
        "id": "roads-trunk",
        "type": "line",
        "source": "osm",
        "source-layer": "transportation",
        "filter": ["==", "class", "trunk"],
        "paint": {
        "line-color": "#e4af7b",
        "line-width": [
            "interpolate",
            ["linear"],
            ["zoom"],
            10, 1.2,
            14, 4,
            18, 20,
            19, 30
            ]
        }
    },
    {
      "id": "roads-tertiary",
      "type": "line",
      "source": "osm",
      "source-layer": "transportation",
      "filter": ["in", "class", "tertiary", "minor"],
      "paint": {
        "line-color": "#000000",
        "line-width": [
            "interpolate",
            ["linear"],
            ["zoom"],
            10, 1.2,
            14, 1.5,
            18, 10
            ]
      }
    },
    {
      "id": "roads-primary",
      "type": "line",
      "source": "osm",
      "source-layer": "transportation",
      "filter": ["==", "class", "primary"],
      "paint": {
        "line-color": "#e4af7b",
        "line-width": [
            "interpolate",
            ["linear"],
            ["zoom"],
            10, 1.2,
            14, 2.5,
            18, 20
            ]
      }
    },
    {
      "id": "roads-secondary",
      "type": "line",
      "source": "osm",
      "source-layer": "transportation",
      "filter": ["==", "class", "secondary"],
      "paint": {
        "line-color": "#e4af7b",
        "line-width": [
            "interpolate",
            ["linear"],
            ["zoom"],
            10, 1.2,
            14, 2.5,
            18, 15
            ]
        }
    },
    {
      "id": "paths",
      "type": "line",
      "source": "osm",
      "source-layer": "transportation",
      "filter": ["in", "class", "path", "footway", "track"],
      "paint": {
        "line-color": "#000000",
        "line-width": 1,
        "line-dasharray": [3, 3]
      }
    },
    {
        "id": "buildings-2d",
        "type": "fill",
        "source": "osm",
        "source-layer": "building",
        "layout": {
            "visibility": "visible"
        },
        "paint": {
            "fill-color": "#231f20",
            "fill-opacity": 1
        }
        
    },
    {
        "id": "buildings-3d",
        "type": "fill-extrusion",
        "source": "osm",
        "source-layer": "building",
        "layout": {
            "visibility": "none"
        },
        "minzoom": 14,
        "paint": {
            "fill-extrusion-color": "#231f20",
            "fill-extrusion-height": [
            "coalesce",
            ["get", "render_height"],
            ["get", "height"],
            10
            ],
            "fill-extrusion-base": [
            "coalesce",
            ["get", "min_height"],
            0
            ],
            "fill-extrusion-opacity": 1
        }
    }
  ]
}