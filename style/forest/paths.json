{
  "layers": [
    {
      "id": "vehicle-track",
      "type": "line",
      "source": "osm",
      "source-layer": "transportation",
      "filter": ["in", "subclass", "footway", "pedestrian", "cycleway", "bridleway"],
      "paint": {
        "line-color": "#000000",
        "line-width": [
            "interpolate",
            ["linear"],
            ["zoom"],
            14, 1.5,
            18, 5
            ],
        "line-dasharray": [6, 1]
      }
    },
    {
      "id": "vehicle-track2",
      "type": "line",
      "source": "osm",
      "source-layer": "transportation",
      "filter": ["in", "class", "track"],
      "paint": {
        "line-color": "#000000",
        "line-width": [
            "interpolate",
            ["linear"],
            ["zoom"],
            14, 1.5,
            18, 5
            ],
        "line-dasharray": [6, 1]
      }
    },
    {
      "id": "footpath",
      "type": "line",
      "source": "osm",
      "source-layer": "transportation",
      "filter": ["in", "subclass", "path", "steps"],
      "paint": {
        "line-color": "#000000",
        "line-width": [
            "interpolate",
            ["linear"],
            ["zoom"],
            14, 1.3,
            18, 4
            ],
        "line-dasharray": [3, 1]
      }
    }
  ]
}