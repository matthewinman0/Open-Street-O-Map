{
  "layers": [
    {
      "id": "GFC",
      "type": "raster",
      "source": "GFC2020 Terrain",
      "paint": {
        "raster-brightness-min": 1,
        "raster-brightness-max": 1,
        "raster-contrast": 0,
        "raster-saturation": -1,
        "raster-resampling": "linear"}
    },
    {
      "id": "residential-areas",
      "type": "fill",
      "source": "osm",
      "source-layer": "landuse",
      "filter": ["==", "class", "residential"],
      "paint": {
        "fill-color": "#aba537",
        "fill-opacity": 1
      }
    },
    {
      "id": "paved-areas",
      "type": "fill",
      "source": "osm",
      "source-layer": "landuse",
      "filter": ["in", "class", "commercial", "retail"],
      "paint": {
        "fill-color": "#e4af7b",
        "fill-opacity": 1
      }
    },
    {
      "id": "paved-aeroways",
      "type": "fill",
      "source": "osm",
      "source-layer": "aeroway",
      "filter": ["all"],
      "paint": {
        "fill-color": "#e4af7b",
        "fill-opacity": 1
      }
    },
    {
      "id": "landcover-grass",
      "type": "fill",
      "source": "osm",
      "source-layer": "landcover",
      "filter": ["in", "class", "grass", "meadow", "farmland"],
      "paint": {
        "fill-color": "#febe50",
        "fill-opacity": 1
      }
    },
    {
      "id": "rough-open",
      "type":"fill",
      "source": "osm",
      "source-layer": "landcover",
      "filter": ["in", "subclass", "heath"],
      "paint": {
        "fill-color": "#ffdfa4",
        "fill-opacity": 1
      }
    },
    {
      "id": "forrest",
      "type": "fill",
      "source": "osm",
      "source-layer": "landcover",
      "filter": ["in", "subclass", "forest", "wood"],
      "paint": {
        "fill-color": "#ffffff",
        "fill-opacity": 1
      }
    },
    {
      "id": "rocks",
      "type": "fill",
      "source": "osm",
      "source-layer": "landcover",
      "filter": ["in", "subclass", "rock"],
      "paint": {
        "fill-color": "#BCBCBC",
        "fill-opacity": 1
      }
    },
    {
      "id": "Vegetation",
      "type": "fill",
      "source": "osm",
      "source-layer": "landcover",
      "filter": ["in", "subclass", "scrub", "shrubbery"],
      "paint": {
        "fill-color": "#bef4b6",
        "fill-opacity": 1
      }
    },
    {
      "id": "pitches",
      "type": "fill",
      "source": "osm",
      "source-layer": "landuse",
      "filter": ["==", "class", "pitch"],
      "paint": {
        "fill-color": "#c07635",
        "fill-opacity": 1
      }
    },
    {
      "id": "ditches",
      "type": "line",
      "source": "osm",
      "source-layer": "waterway",
      "filter": ["==", "class", "ditch"],

      "paint": {
        "line-color": "#D07500",
        "line-opacity": 1,
        "line-dasharray": [1, 1],
        "line-width": [
              "interpolate",
              ["linear"],
              ["zoom"],
              10, 0.4,
              14, 1,
              18, 10,
              19, 20
              ]

      }
    },
    {
      "id": "hillshade",
      "type": "hillshade",
      "source": "hillshade",
      "layout": {
          "visibility": "visible"
      },
      "paint": {
          "hillshade-shadow-color": "#473B24"
      }
    }
  ]
}