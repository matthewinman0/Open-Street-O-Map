{
  "layers": [
    {
      "id": "residential-areas",
      "type": "fill",
      "source": "osm",
      "source-layer": "landuse",
      "filter": ["==", "class", "residential"],
      "paint": {
        "fill-color": "#aba537",
        "fill-opacity": 1
      }
    },
    {
      "id": "paved-areas",
      "type": "fill",
      "source": "osm",
      "source-layer": "landuse",
      "filter": ["==", "class", "commercial"],
      "paint": {
        "fill-color": "#e4af7b",
        "fill-opacity": 1
      }
    },
    {
      "id": "landcover-grass",
      "type": "fill",
      "source": "osm",
      "source-layer": "landcover",
      "filter": ["in", "class", "grass", "meadow", "farmland"],
      "paint": {
        "fill-color": "#febe50",
        "fill-opacity": 1
      }
    },
    {
      "id": "rough-open",
      "type":"fill",
      "source": "osm",
      "source-layer": "landcover",
      "filter": ["in", "subclass", "heath"],
      "paint": {
        "fill-color": "#ffdfa4",
        "fill-opacity": 1
      }
    },
    {
      "id": "forrest",
      "type": "fill",
