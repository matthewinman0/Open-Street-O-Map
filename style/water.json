{
  "layers": [
    {
      "id": "water-outline",
      "type": "line",
      "source": "osm",
      "source-layer": "water",
      "paint": {
        "line-color": "#000000",
        "line-opacity": 1,
        "line-width": [
              "interpolate",
              ["linear"],
              ["zoom"],
              10, 0.5,
              14, 2.5,
              18, 8,
              19, 20
              ]
      }
    },
    {
      "id": "rivers-outline",
      "type": "line",
      "source": "osm",
      "source-layer": "waterway",
      "filter": ["in", "class", "river"],
      "paint": {
        "line-color": "#000000",
        "line-opacity": 1,
        "line-width": [
              "interpolate",
              ["linear"],
              ["zoom"],
              10, 1.3,
              14, 5,
              18, 32,
              19, 60
              ]
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "osm",
      "source-layer": "water",
      "paint": {
        "fill-color": "#009ddc",
        "fill-opacity": 1
      }
    },
    {
      "id": "streams",
      "type": "line",
      "source": "osm",
      "source-layer": "waterway",
      "filter": ["in", "class", "stream", "canal", "drain"],
      "paint": {
        "line-color": "#009ddc",
        "line-opacity": 1,
        "line-width": [
              "interpolate",
              ["linear"],
              ["zoom"],
              10, 1.2,
              14, 1,
              18, 8,
              19, 30
              ]
      }
    },
    {
      "id": "rivers",
      "type": "line",
      "source": "osm",
      "source-layer": "waterway",
      "filter": ["in", "class", "river"],
      "paint": {
        "line-color": "#009ddc",
        "line-opacity": 1,
        "line-width": [
              "interpolate",
              ["linear"],
              ["zoom"],
              10, 1.2,
              14, 4,
              18, 25,
              19, 50
              ]
      }
    },
    {
      "id": "piers- outline",
      "type": "line",
      "source": "osm",
      "source-layer": "transportation",
      "filter": ["==", "class", "pier"],
      "paint": {
        "line-color": "#000000",
        "line-opacity": 1,
        "line-width": [
            "interpolate",
            ["linear"],
            ["zoom"],
            14, 1.5,
            18, 5
            ]
      }
    },
    {
      "id": "piers",
      "type": "fill",
      "source": "osm",
      "source-layer": "transportation",
      "filter": ["==", "class", "pier"],
      "paint": {
        "fill-color": "#000000",
        "fill-opacity": 1
      }
    }
  ]
}