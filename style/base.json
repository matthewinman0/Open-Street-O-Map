{
  "version": 8,
  "glyphs": "https://demotiles.maplibre.org/font/{fontstack}/{range}.pbf",
  "name": "ISOM Base Style",
  "sources": {
    "osm": {
      "type": "vector",
      "tiles": [
        "https://api.maptiler.com/tiles/v3/{z}/{x}/{y}.pbf?key=SOSAfSwTZ8G9yYdNtF8Z"
      ],
      "minzoom": 0,
      "maxzoom": 14
    },
    "contours": {
      "type": "vector",
      "tiles": [
        "https://api.maptiler.com/tiles/contours-v2/{z}/{x}/{y}.pbf?key=SOSAfSwTZ8G9yYdNtF8Z"
      ],
      "minzoom": 9,
      "maxzoom": 14
    },
    "terrain": {
      "type": "raster-dem",
      "tiles": [
        "https://api.maptiler.com/tiles/terrain-rgb-v2/{z}/{x}/{y}.webp?key=SOSAfSwTZ8G9yYdNtF8Z"
      ],
      "minzoom": 0,
      "maxzoom": 18
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#ffdda3"
      }
    },
    {
      "id": "country-borders",
      "type": "line",
      "source": "osm",
      "source-layer": "boundary",
      "minzoom": 0,
      "maxzoom": 8,
      "filter": [
        "all",
        ["==", "admin_level", 2],
        ["==", "maritime", 0]
      ],
      "paint": {
        "line-color": "#666666",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          1, 0.5,
          5, 2
        ]
      }
    },
    {
      "id": "city-names",
      "type": "symbol",
      "source": "osm",
      "source-layer": "place",
      "filter": [
        "==",
        "class",
        "country"
      ],
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": [
          "interpolate",
          ["linear"],
          ["zoom"],
          6, 10,
          12, 16
        ]
      },
      "paint": {
        "text-color": "#222222",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1
      }
    }
  ],
  "terrain": {
    "source": "terrain",
    "exaggeration": 1
  }
}