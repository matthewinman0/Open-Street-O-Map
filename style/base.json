{
  "version": 8,
  "glyphs": "https://demotiles.maplibre.org/font/{fontstack}/{range}.pbf",
  "name": "ISOM Base Style",
  "sources": {
    "osm": {
      "type": "vector",
      "tiles": [
        "https://tiles.openfreemap.org/planet/20260506_001001_pt/{z}/{x}/{y}.pbf"
      ],
      "minzoom": 0,
      "maxzoom": 14
    },
    "hillshade": {
      "type": "raster-dem",
      "tiles": [
        "https://s3.amazonaws.com/elevation-tiles-prod/terrarium/{z}/{x}/{y}.png"
      ],
      "minzoom": 0,
      "maxzoom": 15,
      "tileSize": 256,
      "encoding": "terrarium"
    },
    "3d terrain": {
      "type": "raster-dem",
      "tiles": [
        "https://s3.amazonaws.com/elevation-tiles-prod/terrarium/{z}/{x}/{y}.png"
      ],
      "minzoom": 0,
      "maxzoom": 18,
      "tileSize": 256,
      "encoding": "terrarium"
    }
  },
  
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#ffdda3"
      }
    },
    {
      "id": "country-borders",
      "type": "line",
      "source": "osm",
      "source-layer": "boundary",
      "minzoom": 0,
      "maxzoom": 8,
      "filter": [
        "all",
        ["==", "admin_level", 2],
        ["==", "maritime", 0]
      ],
      "paint": {
        "line-color": "#666666",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          1, 0.5,
          5, 2
        ]
      }
    }
  ],
  "terrain": {
    "source": "3d terrain"
  }
}